# Supabase (required for CLI `createStateManager` and `npm run start`)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Behavior Phase 4: `npm run behavior:backfill-supabase` and `behavior:live` Supabase sync
# Uses BEHAVIOR_BACKTEST_START / BEHAVIOR_BACKTEST_END / BEHAVIOR_PAIR (see behavior backtest script).
# Node 20+ may require: NODE_OPTIONS=--no-node-snapshot when using isolated-vm analyzers.

# Optional: SQLite import script (`npm run import:sqlite`)
# SQLITE_DB=./data/bot-state.db

# Render / process port for health check (`GET /health`)
# PORT=8787

# Phase 5 — dashboard calls bot `POST /behavior/*` with this Bearer secret (set same value on Vercel as BEHAVIOR_API_SECRET)
BEHAVIOR_API_SECRET=long-random-shared-secret

# Phase 6 — optional crash auto-restart (bot server)
# BOT_AUTO_RESTART=true
# BOT_AUTO_RESTART_MAX=3

# Phase 6 — optional equity drop alerts via Telegram (requires Telegram env vars; compares equity vs configs.initial_balance)
# BOT_EQUITY_ALERT_INTERVAL_MS=300000
# BOT_EQUITY_DROP_ALERT_PCT=15
# BOT_EQUITY_ALERT_COOLDOWN_MS=21600000
