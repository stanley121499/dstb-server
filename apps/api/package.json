{
  "name": "@dstb/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "backtest": "tsx src/scripts/runBacktestCli.ts",
    "backtest:batch": "tsx src/scripts/runBatchBacktests.ts",
    "bot:start": "tsx src/scripts/botCli.ts start",
    "bot:stop": "tsx src/scripts/botCli.ts stop",
    "bot:status": "tsx src/scripts/botCli.ts status",
    "bot:list": "tsx src/scripts/botCli.ts list",
    "bot:restart": "tsx src/scripts/botCli.ts restart",
    "bot:pause": "tsx src/scripts/botCli.ts pause",
    "bot:resume": "tsx src/scripts/botCli.ts resume",
    "bot:run": "tsx src/scripts/botCli.ts run",
    "bot:test": "tsx src/scripts/testBitunixConnection.ts",
    "bot:forever": "tsx src/scripts/runBotForever.ts",
    "export-params": "tsx src/scripts/exportBestParams.ts",
    "paper:test": "tsx src/live/testPaperTrading.ts",
    "prelaunch:check": "tsx src/scripts/preLaunchChecklist.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm run build",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "@supabase/supabase-js": "^2.57.4",
    "dotenv": "^17.2.2",
    "fastify": "^5.4.0",
    "luxon": "^3.7.0",
    "ws": "^8.18.3",
    "yahoo-finance2": "^3.10.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.23.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^2.1.8"
  }
}
