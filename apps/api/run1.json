{
  "description": "Example grid search config with industry-standard parameter ranges for ORB+ATR strategy optimization",
  "symbols": ["BTC-USD", "ETH-USD", "ZEC-USD"],
  "intervals": ["5m", "15m", "30m", "1h"],
  "dateRange": {
    "start": "2025-01-01T00:00:00.000Z",
    "end": "2025-12-31T23:59:00.000Z"
  },
  "initialEquity": 10000,
  "baseParams": {
    "version": "1.0",
    "session": {
      "timezone": "America/New_York",
      "startTime": "09:30",
      "openingRangeMinutes": 30
    },
    "entry": {
      "directionMode": "long_short",
      "entryMode": "close_confirm",
      "breakoutBufferBps": 5,
      "maxTradesPerSession": 1
    },
    "atr": {
      "atrLength": 14,
      "atrFilter": {
        "enabled": true,
        "minAtrBps": 50,
        "maxAtrBps": 500
      }
    },
    "risk": {
      "sizingMode": "fixed_risk_pct",
      "riskPctPerTrade": 2,
      "fixedNotional": 1000,
      "stopMode": "atr_multiple",
      "atrStopMultiple": 2.0,
      "takeProfitMode": "r_multiple",
      "tpRMultiple": 3.0,
      "trailingStopMode": "disabled",
      "atrTrailMultiple": 2.5,
      "timeExitMode": "session_end",
      "barsAfterEntry": 0,
      "sessionEndTime": "16:00"
    },
    "execution": {
      "feeBps": 10,
      "slippageBps": 5
    }
  },
  "overrides": [
    {
      "path": "session.openingRangeMinutes",
      "values": [5, 30, 60],
      "description": "Opening range duration - Lower = more trades, Higher = better confirmation"
    },
    {
      "path": "risk.riskPctPerTrade",
      "values": [3],
      "description": "Risk per trade - Professionals use 1-2%, never exceed 5%"
    },
    {
      "path": "risk.atrStopMultiple",
      "values": [1.5, 3.0],
      "description": "Stop loss ATR multiple - Lower = tighter stop, Higher = more room"
    },
    {
      "path": "risk.tpRMultiple",
      "values": [2, 3],
      "description": "Take profit R-multiple - 2R = conservative, 3R = balanced, 4R+ = aggressive"
    },
    {
      "path": "entry.breakoutBufferBps",
      "values": [5],
      "description": "Entry buffer beyond OR level (bps)"
    },
    {
      "path": "atr.atrLength",
      "values": [10, 20],
      "description": "ATR calculation period (bars)"
    },
    {
      "path": "atr.atrFilter.minAtrBps",
      "values": [30, 100],
      "description": "Min ATR in basis points"
    },
    {
      "path": "atr.atrFilter.maxAtrBps",
      "values": [300, 1000],
      "description": "Max ATR in basis points"
    },
    {
      "path": "risk.stopMode",
      "values": ["or_opposite", "or_midpoint", "atr_multiple"],
      "description": "Stop loss placement method"
    },
    {
      "path": "risk.trailingStopMode",
      "values": ["disabled", "atr_trailing"],
      "description": "Trailing stop mode"
    },
    {
      "path": "risk.atrTrailMultiple",
      "values": [2.0, 3.0],
      "description": "Trailing stop ATR multiple"
    },
    {
      "path": "risk.timeExitMode",
      "values": ["disabled", "bars_after_entry", "session_end"],
      "description": "Time-based exit mode"
    },
    {
      "path": "risk.barsAfterEntry",
      "values": [0 ,10],
      "description": "Bars after entry to exit"
    },
    {
      "path": "risk.sessionEndTime",
      "values": ["15:00"],
      "description": "Session end time (HH:mm NY)"
    }
  ],
  "options": {
    "concurrency": 16,
    "outputFile": "optimization-results/run2.jsonl"
  },
  "notes": [
    "This config generates 1 × 2 × 3 × 3 × 3 × 3 × 3 = 486 tests",
    "Start small, confirm output looks right, then widen ranges",
    "Results are written to JSONL for Google Sheets import",
    "Adjust 'concurrency' based on your CPU cores (default: 10)"
  ]
}
