{
  "name": "dstb",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.9.3",
  "scripts": {
    "bootstrap": "npm install",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/ --ext .ts",
    "test:core": "vitest run --config vitest.config.ts",
    "bot": "node --import tsx src/cli/index.ts",
    "start": "node --import tsx src/server/index.ts",
    "paper:validate": "tsx src/scripts/paperValidation.ts",
    "benchmark:perf": "tsx src/scripts/performanceBenchmark.ts",
    "behavior:backtest": "npx tsx src/behavior/scripts/runBehaviorBacktest.ts",
    "behavior:live": "npm run bot -- behavior:live",
    "behavior:backfill-supabase": "npm run bot -- behavior:backfill-supabase",
    "import-results": "tsx src/scripts/importOptimizationResults.ts",
    "import:sqlite": "tsx src/scripts/sqliteToSupabaseImport.ts",
    "preinstall": "npx --yes only-allow npm",
    "dashboard:dev": "npm run dev -w dashboard",
    "dashboard:build": "npm run build -w dashboard"
  },
  "bin": {
    "bot": "bin/bot.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.3.1",
    "googleapis": "^149.0.0",
    "isolated-vm": "^6.1.2",
    "luxon": "^3.7.0",
    "nodemailer": "^6.9.16",
    "tsx": "^4.20.3",
    "ws": "^8.18.3",
    "yahoo-finance2": "^3.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^6.4.17",
    "@types/ws": "^8.5.10",
    "better-sqlite3": "^11.8.1",
    "only-allow": "^1.2.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "workspaces": [
    "dashboard"
  ]
}
