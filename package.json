{
  "name": "dstb",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev:api": "npm run -w apps/api dev --if-present",
    "dev:web": "npm run -w apps/web dev --if-present",
    "build": "npm run -ws build --if-present",
    "typecheck": "npm run -ws typecheck --if-present",
    "lint": "npm run -ws lint --if-present",
    "test:core": "vitest run --config vitest.config.ts",
    "bot": "node --import tsx src/cli/index.ts",
    "paper:validate": "tsx src/scripts/paperValidation.ts",
    "benchmark:perf": "tsx src/scripts/performanceBenchmark.ts",
    "clean": "npm run -ws clean --if-present",
    "import-results": "cd apps/api && npx tsx src/scripts/importOptimizationResults.ts",
    "preinstall": "npx --yes only-allow npm"
  },
  "bin": {
    "bot": "bin/bot.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^17.2.3",
    "googleapis": "^149.0.0",
    "luxon": "^3.7.0",
    "nodemailer": "^6.9.16",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^6.4.17",
    "only-allow": "^1.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
